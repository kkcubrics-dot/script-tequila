# Script Tequila local environment
# Fill this file as .env.local in the same directory.

# Preferred OpenAI key used by the backend when Config API Key is empty.
OPENAI_API_KEY=

# Optional custom base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional alias variable that is also supported by the app.
# CODEX_OPENAI_API_KEY=
